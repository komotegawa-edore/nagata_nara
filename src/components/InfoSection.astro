---
import SectionTitle from "./SectionTitle.astro";
import { storeInfo } from "../data/storeInfo";

const infoRows = [
  { label: "住所", value: storeInfo.address },
  { label: "電話番号", value: storeInfo.phone },
  { label: "アクセス", value: storeInfo.access },
  ...storeInfo.hours.map((h) => ({
    label: `営業時間（${h.label}）`,
    value: h.time,
  })),
  { label: "営業日", value: storeInfo.businessDays },
  { label: "定休日", value: storeInfo.closedDay },
  { label: "席数", value: storeInfo.seats },
  { label: "お支払い", value: storeInfo.payment },
];
---

<section id="info" class="py-24 md:py-32 px-4 bg-card">
  <div class="max-w-3xl mx-auto">
    <div class="fade-up">
      <SectionTitle title="店舗情報" subtitle="INFORMATION" />
    </div>

    <div class="fade-up">
      <table class="w-full text-sm">
        <tbody>
          {
            infoRows.map((row) => (
              <tr class="border-b border-border/30">
                <th class="py-4 pr-6 text-left text-foreground font-medium w-40 align-top whitespace-nowrap">
                  {row.label}
                </th>
                <td class="py-4 text-foreground/80">{row.value}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <div class="mt-10 aspect-[16/9] fade-in">
      <iframe
        src={storeInfo.googleMapsEmbed}
        width="100%"
        height="100%"
        style="border:0"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>
  </div>
</section>
