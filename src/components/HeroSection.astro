---
import { storeInfo } from "../data/storeInfo";
---

<section
  class="relative min-h-screen flex items-center justify-center overflow-hidden bg-card"
>
  <!-- Content -->
  <div class="relative z-20 text-center px-4">
    <div class="mb-8 animate-fade-in">
      <img
        src="/icon.jpg"
        alt="酒と肴 なが田"
        width="200"
        height="200"
        class="mx-auto w-40 h-40 md:w-52 md:h-52 object-contain"
      />
    </div>

    <p
      class="font-[family-name:var(--font-display)] text-muted tracking-[0.5em] text-xs md:text-sm uppercase mb-4 animate-slide-up"
      style="animation-delay: 0.3s"
    >
      {storeInfo.nameEn}
    </p>

    <p
      class="text-sm md:text-base text-foreground/70 tracking-widest animate-slide-up"
      style="animation-delay: 0.6s"
    >
      {storeInfo.catchphrase}
    </p>

    <div class="mt-10 animate-slide-up" style="animation-delay: 0.9s">
      <a
        href="#concept"
        class="inline-block border border-foreground/30 text-foreground/60 text-xs tracking-widest px-6 py-3 hover:bg-foreground hover:text-background transition-all duration-300"
      >
        SCROLL
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 animate-bounce-slow">
    <div
      class="w-[1px] h-12 bg-gradient-to-b from-foreground/0 to-foreground/40"
    >
    </div>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes bounceSlow {
    0%,
    100% {
      transform: translateX(-50%) translateY(0);
    }
    50% {
      transform: translateX(-50%) translateY(8px);
    }
  }

  .animate-fade-in {
    animation: fadeIn 1s ease forwards;
  }

  .animate-slide-up {
    opacity: 0;
    animation: slideUp 1s ease forwards;
  }

  .animate-bounce-slow {
    animation: bounceSlow 2s ease-in-out infinite;
  }
</style>
