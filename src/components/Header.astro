---
const navLinks = [
  { href: "/#concept", label: "こだわり" },
  { href: "/menu", label: "メニュー" },
  { href: "/access", label: "アクセス" },
];
---

<header
  class="fixed top-0 left-0 right-0 z-50 bg-background/90 backdrop-blur-md border-b border-border"
>
  <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16 md:h-20">
    <a href="/" class="flex items-center gap-3">
      <img
        src="/icon.png"
        alt="酒と肴 なが田"
        width="44"
        height="44"
        class="h-10 w-10 md:h-11 md:w-11 object-contain rounded-full"
      />
      <span class="text-base md:text-lg font-bold tracking-wider">
        酒と肴 なが田
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm tracking-wider text-foreground/70 hover:text-accent transition-colors"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- Mobile menu button -->
    <button
      id="menu-toggle"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="メニューを開く"
    >
      <span
        class="block w-6 h-[2px] bg-foreground transition-transform duration-300 origin-center"
        id="bar1"></span>
      <span
        class="block w-6 h-[2px] bg-foreground transition-opacity duration-300"
        id="bar2"></span>
      <span
        class="block w-6 h-[2px] bg-foreground transition-transform duration-300 origin-center"
        id="bar3"></span>
    </button>
  </div>

  <!-- Mobile nav -->
  <nav
    id="mobile-nav"
    class="md:hidden bg-background border-t border-border transition-all duration-300 overflow-hidden max-h-0"
  >
    <div class="flex flex-col py-4">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="mobile-link px-6 py-3 text-sm tracking-wider text-foreground/70 hover:text-accent hover:bg-card transition-colors"
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const mobileNav = document.getElementById("mobile-nav");
  const bar1 = document.getElementById("bar1");
  const bar2 = document.getElementById("bar2");
  const bar3 = document.getElementById("bar3");
  let isOpen = false;

  toggle?.addEventListener("click", () => {
    isOpen = !isOpen;
    if (isOpen) {
      mobileNav!.style.maxHeight = "320px";
      bar1!.style.transform = "rotate(45deg) translateY(7px)";
      bar2!.style.opacity = "0";
      bar3!.style.transform = "rotate(-45deg) translateY(-7px)";
    } else {
      mobileNav!.style.maxHeight = "0";
      bar1!.style.transform = "";
      bar2!.style.opacity = "";
      bar3!.style.transform = "";
    }
  });

  document.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", () => {
      isOpen = false;
      mobileNav!.style.maxHeight = "0";
      bar1!.style.transform = "";
      bar2!.style.opacity = "";
      bar3!.style.transform = "";
    });
  });
</script>
