---
import { storeInfo } from "../data/storeInfo";
---

<section class="py-24 md:py-32 px-4">
  <div class="max-w-2xl mx-auto text-center">
    <div class="fade-up">
      <p
        class="font-[family-name:var(--font-display)] text-muted tracking-[0.3em] text-sm uppercase mb-2"
      >
        CONTACT
      </p>
      <h2 class="text-2xl md:text-3xl font-bold tracking-wider mb-4">
        ご予約・お問い合わせ
      </h2>
      <div class="w-16 h-[1px] bg-foreground/30 mx-auto mb-8"></div>
      <p class="text-sm text-foreground/60 mb-10 leading-relaxed">
        お電話・Instagram DMにてご予約を承っております。<br />
        お気軽にお問い合わせください。
      </p>
    </div>

    <div class="flex flex-col sm:flex-row gap-4 justify-center fade-up">
      <a
        href={`tel:${storeInfo.phone.replace(/-/g, "")}`}
        class="inline-block bg-accent text-white text-sm tracking-wider px-8 py-3 hover:bg-accent-dark transition-colors duration-300"
      >
        電話する
      </a>
      <a
        href={storeInfo.instagram}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block border border-foreground/30 text-foreground text-sm tracking-wider px-8 py-3 hover:bg-foreground hover:text-background transition-all duration-300"
      >
        Instagram DM
      </a>
    </div>
  </div>
</section>
