---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="text-center mb-12">
  {
    subtitle && (
      <p class="font-[family-name:var(--font-display)] text-muted tracking-[0.3em] text-sm uppercase mb-2">
        {subtitle}
      </p>
    )
  }
  <h2 class="text-2xl md:text-3xl font-bold tracking-wider">{title}</h2>
  <div class="w-16 h-[1px] bg-foreground/30 mx-auto mt-4"></div>
</div>
